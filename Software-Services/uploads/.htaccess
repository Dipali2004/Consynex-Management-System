# ----------------------------------------------------------------------
# | Uploads Directory Hardening - Prevent Execution
# ----------------------------------------------------------------------

# 1. Disable PHP Execution in Uploads
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# 2. Block all scripts and executable files
<FilesMatch "\.(php|php5|php7|php8|phtml|pl|py|cgi|sh|exe)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# 3. Disable Directory Browsing
Options -Indexes
